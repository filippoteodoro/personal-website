# Google Analytics 4
# Measurement ID (public identifier, not a secret). Leave empty to disable GA.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google reCAPTCHA v3
# Get keys at https://www.google.com/recaptcha/admin (select Score based v3)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=   # public key, safe to expose
RECAPTCHA_SECRET_KEY=             # secret key, server-side only
# Optional: comma-separated hostnames allowed by server verification.
RECAPTCHA_EXPECTED_HOSTNAMES=filippoteodoro.com,localhost

# Web3Forms
# Get access key at https://web3forms.com (free, no domain verification needed)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY= # public key, safe to expose
