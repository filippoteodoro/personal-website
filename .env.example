# Google reCAPTCHA v3
# Get keys at https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=   # public key — safe to expose
RECAPTCHA_SECRET_KEY=             # secret key — server-side only, never expose

# Resend (email)
# Get API key at https://resend.com
# Domain must be verified in Resend dashboard
RESEND_API_KEY=

